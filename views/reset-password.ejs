<!DOCTYPE html>
<html lang="en" class="h-full bg-gradient-to-br from-gray-900 to-gray-800">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset Password - NetDiag Toolbox</title>
  <link rel="icon" type="image/svg+xml" href="/static/icon.svg">
  <link rel="stylesheet" href="/static/css/tailwind.css">
  <link rel="stylesheet" href="/static/css/app.css">
</head>
<body class="auth-page-bg h-full font-sans text-gray-900 flex items-center justify-center p-4">
  <%- include('partials/theme-init') %>
  <button id="theme-toggle" class="fixed top-4 right-4 inline-flex items-center justify-center px-2 py-2 rounded text-gray-700 bg-white/90 hover:bg-gray-100 shadow transition" title="Toggle dark mode" aria-label="Toggle dark mode">
    <span id="theme-toggle-icon" class="inline-flex items-center justify-center" aria-hidden="true">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.742 13.045A8.088 8.088 0 0110.955 3.258 9 9 0 1020.742 13.045z"/></svg>
    </span>
  </button>
  <div class="w-full max-w-md">
    <!-- Card -->
    <div class="auth-card bg-white rounded-lg shadow-2xl p-8">
      <!-- Logo/Header -->
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-[#9D003A]">Reset Password</h1>
        <p class="text-sm text-gray-600 mt-1">Enter your new password</p>
      </div>

      <!-- Alert Messages -->
      <div id="error-alert" class="hidden mb-4 bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded text-sm">
        <span id="error-message"></span>
      </div>

      <div id="success-alert" class="hidden mb-4 bg-green-50 border border-green-200 text-green-600 px-4 py-3 rounded text-sm">
        Password reset successfully! Redirecting to login...
      </div>

      <!-- Reset Form -->
      <form id="reset-form" class="space-y-4">
        <!-- New Password -->
        <div>
          <label for="new-password" class="block text-sm font-semibold text-gray-700 mb-1">New Password</label>
          <input
            type="password"
            id="new-password"
            placeholder="Enter new password"
            required
            minlength="6"
            class="w-full px-4 py-2 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-500 focus:ring-2 focus:ring-[#9D003A] focus:border-transparent focus:outline-none transition"
          >
          <p class="text-xs text-gray-500 mt-1">Minimum 6 characters</p>
        </div>

        <!-- Confirm Password -->
        <div>
          <label for="confirm-password" class="block text-sm font-semibold text-gray-700 mb-1">Confirm Password</label>
          <input
            type="password"
            id="confirm-password"
            placeholder="Confirm password"
            required
            minlength="6"
            class="w-full px-4 py-2 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-500 focus:ring-2 focus:ring-[#9D003A] focus:border-transparent focus:outline-none transition"
          >
        </div>

        <!-- Submit Button -->
        <button
          type="submit"
          class="w-full bg-[#9D003A] hover:bg-[#72002E] text-white font-semibold py-2 px-4 rounded-lg transition duration-200 focus:outline-none focus:ring-2 focus:ring-[#9D003A] focus:ring-offset-2"
        >
          Reset Password
        </button>
      </form>

      <!-- Back to Login Link -->
      <div class="mt-6 text-center">
        <a href="/" class="text-sm text-[#9D003A] hover:text-[#72002E] font-medium">
          Back to Login
        </a>
      </div>
    </div>
  </div>

  <script src="/static/js/theme.js"></script>
  <script src="/static/js/reset-password.js"></script>
</body>
</html>

