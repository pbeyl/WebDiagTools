<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-100">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Settings - NetDiag Toolbox</title>
  <link rel="icon" type="image/svg+xml" href="/static/icon.svg">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/static/css/app.css">
</head>
<body class="h-full font-sans text-gray-900">
  <div class="flex flex-col h-full">

    <!-- Reset Password Modal -->
    <div id="reset-password-modal" class="hidden fixed inset-0 bg-gray-900 bg-opacity-50 flex items-center justify-center z-50">
      <div class="bg-white rounded-lg shadow-lg p-6 w-full max-w-md">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xl font-bold text-gray-900">Reset Password</h2>
        </div>
        <form id="reset-password-form" class="space-y-4">
          <div>
            <label for="new-password" class="block text-sm font-semibold text-gray-700 mb-1">New Password</label>
            <input type="password" id="new-password" required class="w-full bg-white border border-gray-300 text-gray-900 text-sm rounded p-2 focus:ring-2 focus:ring-[#9D003A] focus:border-[#9D003A] focus:outline-none">
          </div>
          <div>
            <label for="confirm-password" class="block text-sm font-semibold text-gray-700 mb-1">Confirm Password</label>
            <input type="password" id="confirm-password" required class="w-full bg-white border border-gray-300 text-gray-900 text-sm rounded p-2 focus:ring-2 focus:ring-[#9D003A] focus:border-[#9D003A] focus:outline-none">
          </div>
          <div id="password-error" class="hidden text-red-600 text-sm"></div>
          <div id="password-success" class="hidden text-green-600 text-sm"></div>
          <div class="flex gap-2 pt-2">
            <button type="button" id="cancel-reset" class="flex-1 px-4 py-2 text-gray-700 bg-gray-200 hover:bg-gray-300 rounded font-semibold transition">
              Cancel
            </button>
            <button type="submit" class="flex-1 px-4 py-2 text-white bg-[#9D003A] hover:bg-[#72002E] rounded font-semibold transition">
              Reset Password
            </button>
          </div>
        </form>
        <!-- success-actions removed: no explicit logout button shown after password change -->
      </div>
    </div>

    <%- include('partials/header') %>

    <!-- Main Content -->
    <div class="flex-grow overflow-y-auto">
      <div class="max-w-7xl mx-auto px-4 py-6">
        <!-- Alerts -->
        <div id="success-alert" class="hidden mb-4 bg-green-50 border border-green-200 text-green-600 px-4 py-3 rounded">
          <span id="success-message"></span>
        </div>
        <div id="error-alert" class="hidden mb-4 bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded">
          <span id="error-message"></span>
        </div>

        <!-- Tab Navigation -->
        <div class="flex gap-4 mb-6 border-b border-gray-200">
          <button class="tab-button active px-4 py-2 font-semibold text-gray-700 hover:text-[#9D003A]" data-tab="users-tab">
            Manage Users
          </button>
          <button class="tab-button px-4 py-2 font-semibold text-gray-700 hover:text-[#9D003A]" data-tab="roles-tab">
            Manage Roles
          </button>
        </div>

        <!-- Users Tab -->
        <div id="users-tab" class="tab-content active">
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Create/Edit User Form -->
            <div class="bg-white rounded-lg shadow p-6">
              <h2 class="text-xl font-bold mb-4 text-gray-900">
                <span id="form-title">Create New User</span>
              </h2>
              <form id="user-form" class="space-y-4">
                <input type="hidden" id="user-id">

                <div>
                  <label for="username" class="block text-sm font-semibold text-gray-700 mb-1">Username</label>
                  <input
                    type="text"
                    id="username"
                    required
                    class="w-full px-3 py-2 border border-gray-300 rounded text-sm focus:ring-2 focus:ring-[#9D003A] focus:border-transparent focus:outline-none"
                  >
                </div>

                <div>
                  <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">Email (Optional)</label>
                  <input
                    type="email"
                    id="email"
                    class="w-full px-3 py-2 border border-gray-300 rounded text-sm focus:ring-2 focus:ring-[#9D003A] focus:border-transparent focus:outline-none"
                  >
                </div>

                <div>
                  <label for="password" class="block text-sm font-semibold text-gray-700 mb-1">
                    Password
                    <span id="password-hint" class="text-xs text-gray-500 font-normal">(Leave blank to keep current)</span>
                  </label>
                  <input
                    type="password"
                    id="password"
                    class="w-full px-3 py-2 border border-gray-300 rounded text-sm focus:ring-2 focus:ring-[#9D003A] focus:border-transparent focus:outline-none"
                  >
                </div>

                <div>
                  <label for="role" class="block text-sm font-semibold text-gray-700 mb-1">Role</label>
                  <select id="role" class="w-full px-3 py-2 border border-gray-300 rounded text-sm focus:ring-2 focus:ring-[#9D003A] focus:border-transparent focus:outline-none">
                    <option value="">Select a role...</option>
                  </select>
                </div>

                <div>
                  <label for="status" class="block text-sm font-semibold text-gray-700 mb-1">Status</label>
                  <select id="status" class="w-full px-3 py-2 border border-gray-300 rounded text-sm focus:ring-2 focus:ring-[#9D003A] focus:border-transparent focus:outline-none">
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                  </select>
                </div>

                <div class="flex gap-2">
                  <button type="submit" class="flex-1 bg-[#9D003A] hover:bg-[#72002E] text-white font-semibold py-2 rounded transition">
                    Save User
                  </button>
                  <button type="button" id="cancel-edit" class="flex-1 bg-gray-300 hover:bg-gray-400 text-gray-900 font-semibold py-2 rounded transition hidden">
                    Cancel
                  </button>
                </div>
              </form>
            </div>

            <!-- Users List -->
            <div class="lg:col-span-2 bg-white rounded-lg shadow overflow-hidden">
              <div class="p-6 border-b border-gray-200">
                <h2 class="text-xl font-bold text-gray-900">Users</h2>
              </div>
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead class="bg-gray-50">
                    <tr>
                      <th class="px-6 py-3 text-left font-semibold text-gray-700">Username</th>
                      <th class="px-6 py-3 text-left font-semibold text-gray-700">Email</th>
                      <th class="px-6 py-3 text-left font-semibold text-gray-700">Role</th>
                      <th class="px-6 py-3 text-left font-semibold text-gray-700">Status</th>
                      <th class="px-6 py-3 text-center font-semibold text-gray-700">Actions</th>
                    </tr>
                  </thead>
                  <tbody id="users-table" class="divide-y divide-gray-200">
                    <tr>
                      <td colspan="5" class="px-6 py-4 text-center text-gray-500">Loading users...</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- Manage Roles Tab -->
        <div id="roles-tab" class="tab-content">
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Create/Edit Role Form -->
            <div class="bg-white rounded-lg shadow p-6">
              <h2 class="text-xl font-bold mb-4 text-gray-900">
                <span id="role-form-title">Create New Role</span>
              </h2>
              <form id="role-form" class="space-y-4">
                <input type="hidden" id="role-id">

                <div>
                  <label for="role-name" class="block text-sm font-semibold text-gray-700 mb-1">Role Name</label>
                  <input
                    type="text"
                    id="role-name"
                    required
                    class="w-full px-3 py-2 border border-gray-300 rounded text-sm focus:ring-2 focus:ring-[#9D003A] focus:border-transparent focus:outline-none"
                  >
                </div>

                <div>
                  <label for="role-description" class="block text-sm font-semibold text-gray-700 mb-1">Description</label>
                  <textarea
                    id="role-description"
                    rows="2"
                    class="w-full px-3 py-2 border border-gray-300 rounded text-sm focus:ring-2 focus:ring-[#9D003A] focus:border-transparent focus:outline-none"
                  ></textarea>
                </div>

                <div class="flex gap-2">
                  <button type="submit" class="flex-1 bg-[#9D003A] hover:bg-[#72002E] text-white font-semibold py-2 rounded transition">
                    Save Role
                  </button>
                  <button type="button" id="role-cancel-edit" class="flex-1 bg-gray-300 hover:bg-gray-400 text-gray-900 font-semibold py-2 rounded transition hidden">
                    Cancel
                  </button>
                </div>
              </form>
            </div>

            <!-- Roles List & Permissions -->
            <div class="lg:col-span-2">
              <!-- Roles List -->
              <div class="bg-white rounded-lg shadow overflow-hidden mb-6">
                <div class="p-6 border-b border-gray-200">
                  <h2 class="text-xl font-bold text-gray-900">Roles</h2>
                </div>
                <div class="overflow-x-auto">
                  <table class="w-full text-sm">
                    <thead class="bg-gray-50">
                      <tr>
                        <th class="px-6 py-3 text-left font-semibold text-gray-700">Name</th>
                        <th class="px-6 py-3 text-left font-semibold text-gray-700">Permissions</th>
                        <th class="px-6 py-3 text-center font-semibold text-gray-700">Actions</th>
                      </tr>
                    </thead>
                    <tbody id="roles-table" class="divide-y divide-gray-200">
                      <tr>
                        <td colspan="3" class="px-6 py-4 text-center text-gray-500">No roles found</td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>

              <!-- Role Permissions Manager -->
              <div id="role-permissions-container" class="hidden bg-white rounded-lg shadow p-6">
                <h2 class="text-xl font-bold mb-4 text-gray-900">
                  <span id="selected-role-name"></span> - Permissions
                </h2>
                <div id="role-permissions-list" class="grid grid-cols-1 gap-3">
                  <!-- Permissions will be populated here -->
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Edit User/Role Delete Confirmation Modal -->
  <div id="edit-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
    <div class="bg-white rounded-lg p-6 w-full max-w-md">
      <h2 class="text-lg font-bold mb-4">Confirm Delete</h2>
      <p class="text-gray-600 mb-6">Are you sure you want to delete this item?</p>
      <div class="flex gap-2">
        <button id="confirm-delete" class="flex-1 bg-[#9D003A] hover:bg-red-700 text-white font-semibold py-2 rounded transition">
          Delete
        </button>
        <button id="cancel-delete" class="flex-1 bg-gray-300 hover:bg-gray-400 text-gray-900 font-semibold py-2 rounded transition">
          Cancel
        </button>
      </div>
    </div>
  </div>

  <script src="/static/js/admin.js"></script>
</body>
</html>

