<header class="bg-white shadow border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
    <h1 class="text-2xl font-bold text-[#9D003A]">NetDiag Toolbox</h1>
    <div class="flex items-center gap-4 relative">
      <!-- Header navigation links -->
      <nav class="hidden sm:flex items-center gap-2">
        <a id="header-dashboard-link" href="/dashboard" class="flex items-center gap-2 px-3 py-2 rounded font-semibold text-sm text-gray-700 hover:bg-[#9D003A] hover:text-white transition <%= (typeof activePage !== 'undefined' && activePage === 'dashboard') ? 'bg-[#9D003A] text-white' : '' %>">
          <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 2.5L2 8.5V17a1 1 0 001 1h4v-5a1 1 0 011-1h2a1 1 0 011 1v5h4a1 1 0 001-1V8.5L10 2.5z"/></svg>
          Dashboard
        </a>
        <a id="header-admin-link" href="/admin" class="flex items-center gap-2 px-3 py-2 rounded font-semibold text-sm text-gray-700 hover:bg-[#9D003A] hover:text-white transition <%= (typeof activePage !== 'undefined' && activePage === 'admin') ? 'bg-[#9D003A] text-white' : '' %>">
          <svg xmlns="http://www.w3.org/2000/svg" role="img" focusable="false" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19.14 12.94c.04-.31.06-.63.06-.94s-.02-.63-.06-.94l2.03-1.58a.5.5 0 0 0 .12-.64l-1.92-3.32a.5.5 0 0 0-.6-.22l-2.39.96a7.28 7.28 0 0 0-1.63-.94l-.36-2.54A.5.5 0 0 0 13.9 2h-3.8a.5.5 0 0 0-.49.42l-.36 2.54c-.58.23-1.12.54-1.63.94l-2.39-.96a.5.5 0 0 0-.6.22L2.71 8.48a.5.5 0 0 0 .12.64l2.03 1.58c-.04.31-.06.63-.06.94s.02.63.06.94l-2.03 1.58a.5.5 0 0 0-.12.64l1.92 3.32c.14.24.43.34.68.22l2.39-.96c.51.39 1.05.71 1.63.94l.36 2.54c.05.24.25.42.49.42h3.8c.24 0 .44-.18.49-.42l.36-2.54c.58-.23 1.12-.54 1.63-.94l2.39.96c.25.12.54.02.68-.22l1.92-3.32a.5.5 0 0 0-.12-.64l-2.03-1.58zM12 15.5A3.5 3.5 0 1 1 12 8.5a3.5 3.5 0 0 1 0 7z"/>
          </svg>
          Settings
        </a>
      </nav>
      <!-- User menu button -->
      <button id="user-menu-btn" class="flex items-center gap-1 px-4 py-2 bg-gray-200 hover:bg-[#9D003A] hover:text-white text-gray-900 rounded font-semibold transition">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path d="M10 2a4 4 0 100 8 4 4 0 000-8zM2 18a8 8 0 1116 0H2z"/>
        </svg>
        <span id="current-user" class="hidden md:inline text-sm text-gray-600 hover:text-white">Loading...</span>
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
        </svg>
      </button>
      <div id="user-menu" class="hidden absolute right-0 top-full mt-2 w-40 bg-white shadow-lg rounded z-50">
        <!-- Mobile-only nav links (visible inside dropdown on small screens) -->
        <a href="/dashboard" id="dashboard-link" class="sm:hidden flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-[#9D003A] hover:text-white <%= (typeof activePage !== 'undefined' && activePage === 'dashboard') ? 'bg-[#9D003A] text-white' : '' %>">
          <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 2.5L2 8.5V17a1 1 0 001 1h4v-5a1 1 0 011-1h2a1 1 0 011 1v5h4a1 1 0 001-1V8.5L10 2.5z"/></svg>
          Dashboard
        </a>
        <a href="/admin" id="admin-link" class="sm:hidden flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-[#9D003A] hover:text-white <%= (typeof activePage !== 'undefined' && activePage === 'admin') ? 'bg-[#9D003A] text-white' : '' %>">
          <svg xmlns="http://www.w3.org/2000/svg" role="img" focusable="false" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19.14 12.94c.04-.31.06-.63.06-.94s-.02-.63-.06-.94l2.03-1.58a.5.5 0 0 0 .12-.64l-1.92-3.32a.5.5 0 0 0-.6-.22l-2.39.96a7.28 7.28 0 0 0-1.63-.94l-.36-2.54A.5.5 0 0 0 13.9 2h-3.8a.5.5 0 0 0-.49.42l-.36 2.54c-.58.23-1.12.54-1.63.94l-2.39-.96a.5.5 0 0 0-.6.22L2.71 8.48a.5.5 0 0 0 .12.64l2.03 1.58c-.04.31-.06.63-.06.94s.02.63.06.94l-2.03 1.58a.5.5 0 0 0-.12.64l1.92 3.32c.14.24.43.34.68.22l2.39-.96c.51.39 1.05.71 1.63.94l.36 2.54c.05.24.25.42.49.42h3.8c.24 0 .44-.18.49-.42l.36-2.54c.58-.23 1.12-.54 1.63-.94l2.39.96c.25.12.54.02.68-.22l1.92-3.32a.5.5 0 0 0-.12-.64l-2.03-1.58zM12 15.5A3.5 3.5 0 1 1 12 8.5a3.5 3.5 0 0 1 0 7z"/>
          </svg>
          Settings
        </a>
        <button id="reset-password-btn" class="w-full text-left flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-[#9D003A] hover:text-white">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
          </svg>
          Reset Password
        </button>
        <button id="menu-logout" class="w-full text-left flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-[#9D003A] hover:text-white">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
          Logout
        </button>
      </div>
    </div>
  </div>
</header>
