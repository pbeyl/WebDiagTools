<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-100">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NetDiag Toolbox</title>
  <link rel="icon" type="image/svg+xml" href="/static/icon.svg">
  <link rel="stylesheet" href="/static/css/tailwind.css">
  <link rel="stylesheet" href="/static/css/app.css">
</head>
<body class="h-full font-sans text-gray-900">
  <%- include('partials/theme-init') %>
  <!-- Main container -->
  <div class="flex flex-col h-full">

    <%- include('partials/header') %>

    <!-- Main content area -->
    <div class="flex-grow overflow-y-auto">
      <div class="max-w-7xl mx-auto px-4 py-6">
        <div class="flex flex-col md:flex-row h-full gap-6 overflow-hidden">
          
          <!-- Consolidated Header + Form Section - Left side on large screens, max 400px width -->
          <div class="w-full md:max-w-[400px] form-container overflow-y-auto md:overflow-y-visible">
            <div class="bg-white shadow rounded-lg p-4 h-full flex flex-col">
          
          <!-- Controls -->
          <div class="flex flex-col space-y-4 overflow-y-auto">
            <!-- Tool Selector -->
            <div>
              <label for="tool-select" class="block text-sm font-semibold text-gray-700 mb-1">Select Tool</label>
              <select id="tool-select" class="w-full bg-white border border-gray-300 text-gray-900 text-sm rounded p-2 focus:ring-2 focus:ring-[#9D003A] focus:border-[#9D003A] focus:outline-none">
                <option value="ping">Ping</option>
                <option value="nslookup">NSLookup</option>
                <option value="nslookup_bulk">NSLookup (Bulk)</option>
                <option value="traceroute">Traceroute</option>
                <option value="mtr">TCP Traceroute</option>
                <option value="openssl_sconnect">TLS Handshake</option>
                <option value="curl">HTTP Timing Stats</option>
              </select>
            </div>
            
            <!-- Host Input -->
            <div id="host-container" class="hidden">
              <label for="host-input" class="block text-sm font-semibold text-gray-700 mb-1">Host / IP</label>
              <input type="text" id="host-input" placeholder="e.g., google.com" class="w-full bg-white border border-gray-300 text-gray-900 text-sm rounded p-2 placeholder-gray-400 focus:ring-2 focus:ring-[#9D003A] focus:border-[#9D003A] focus:outline-none">
            </div>
            <!-- Ping Options (packet size / don't fragment) -->
            <div id="ping-options" class="hidden space-y-4">
              <div>
                <label for="packet-size-input" class="block text-sm font-semibold text-gray-700 mb-1">Packet Size (bytes)</label>
                <input type="number" id="packet-size-input" placeholder="eg. 1420" min="0" class="w-full bg-white border border-gray-300 text-gray-900 text-sm rounded p-2 placeholder-gray-400 focus:ring-2 focus:ring-[#9D003A] focus:border-[#9D003A] focus:outline-none">
              </div>
              <div class="flex items-center">
                <input id="dont-frag-checkbox" type="checkbox" class="h-3 w-3 text-[#9D003A] border-gray-300 rounded focus:ring-[#9D003A]">
                <label for="dont-frag-checkbox" class="ml-2 text-sm text-gray-900">Don't fragment</label>
              </div>
            </div>

            <!-- Bulk Hosts Input -->
            <div id="bulk-hosts-container" class="hidden">
              <label for="bulk-hosts-input" class="block text-sm font-semibold text-gray-700 mb-1">Hosts (one per line)</label>
              <textarea id="bulk-hosts-input" placeholder="google.com&#10;8.8.8.8" class="w-full bg-white border border-gray-300 text-gray-900 text-sm rounded p-2 placeholder-gray-400 focus:ring-2 focus:ring-[#9D003A] focus:border-[#9D003A] focus:outline-none resize-none" rows="2"></textarea>
            </div>

            <!-- NSLookup Options -->
            <div id="dns-options" class="hidden space-y-4">
              <div>
                <label for="dns-server-input" class="block text-sm font-semibold text-gray-700 mb-1">DNS Server (Opt)</label>
                <input type="text" id="dns-server-input" placeholder="1.1.1.1" class="w-full bg-white border border-gray-300 text-gray-900 text-sm rounded p-2 placeholder-gray-400 focus:ring-2 focus:ring-[#9D003A] focus:border-[#9D003A] focus:outline-none">
              </div>
              <div>
                <label for="record-type-select" class="block text-sm font-semibold text-gray-700 mb-1">Record Type</label>
                <select id="record-type-select" class="w-full bg-white border border-gray-300 text-gray-900 text-sm rounded p-2 focus:ring-2 focus:ring-[#9D003A] focus:border-[#9D003A] focus:outline-none">
                  <option value="A">A</option>
                  <option value="AAAA">AAAA</option>
                  <option value="CNAME">CNAME</option>
                  <option value="MX">MX</option>
                  <option value="TXT">TXT</option>
                  <option value="NS">NS</option>
                  <option value="SOA">SOA</option>
                  <option value="PTR">PTR</option>
                  <option value="SRV">SRV</option>
                  <option value="ANY">ANY</option>
                </select>
              </div>
              <div class="flex items-center">
                <input id="nslookup-debug-checkbox" type="checkbox" class="h-3 w-3 text-[#9D003A] border-gray-300 rounded focus:ring-[#9D003A]">
                <label for="nslookup-debug-checkbox" class="ml-2 text-sm text-gray-900">Debug output</label>
              </div>
            </div>
            
            <!-- MTR Options -->
            <div id="mtr-options" class="hidden">
              <label for="mtr-port-input" class="block text-sm font-semibold text-gray-700 mb-1">TCP Port</label>
              <input type="number" id="mtr-port-input" placeholder="443" min="1" max="65535" class="w-full bg-white border border-gray-300 text-gray-900 text-sm rounded p-2 placeholder-gray-400 focus:ring-2 focus:ring-[#9D003A] focus:border-[#9D003A] focus:outline-none">
            </div>
            
            <!-- OpenSSL Options -->
            <div id="port-option" class="hidden">
              <label for="port-input" class="block text-sm font-semibold text-gray-700 mb-1">Port (Opt)</label>
              <input type="number" id="port-input" placeholder="443" min="1" max="65535" class="w-full bg-white border border-gray-300 text-gray-900 text-sm rounded p-2 placeholder-gray-400 focus:ring-2 focus:ring-[#9D003A] focus:border-[#9D003A] focus:outline-none">
            </div>
            <div id="openssl-option" class="hidden flex items-center">
              <input id="openssl-debug-checkbox" type="checkbox" class="h-3 w-3 text-[#9D003A] border-gray-300 rounded focus:ring-[#9D003A]">
              <label for="openssl-debug-checkbox" class="ml-2 text-sm text-gray-900">Output certs</label>
            </div>
            
            <!-- Curl Options (Protocol) -->
            <div id="curl-options" class="hidden space-y-4">
              <div class="flex items-center">
                <input id="curl-https-checkbox" type="checkbox" checked class="h-3 w-3 text-[#9D003A] border-gray-300 rounded focus:ring-[#9D003A]">
                <label for="curl-https-checkbox" class="ml-2 text-sm text-gray-900">Use HTTPS</label>
              </div>
            </div>
            </div>

            <!-- Run Button - sticky at bottom -->
            <button id="run-button" class="w-full mt-4 bg-[#9D003A] hover:bg-[#72002E] text-white font-bold py-2 px-4 rounded transition duration-200 focus:outline-none focus:ring-2 focus:ring-[#9D003A] focus:ring-offset-2 focus:ring-offset-white disabled:opacity-50 disabled:cursor-not-allowed">
              Run
            </button>
            </div>
          </div>
          
          <!-- Output Section - Right side on large screens, expands to fill width -->
          <div class="w-full md:flex-grow output-container">
            <div class="bg-gray-900 rounded-lg border border-gray-700 overflow-hidden shadow-lg h-full flex flex-col relative">
              <div class="px-3 py-2 bg-gray-800 border-b border-gray-700 flex items-center justify-between">
                <h2 class="text-sm font-semibold text-white">Output</h2>
                <button id="copy-button" class="text-gray-400 hover:text-white transition-colors focus:outline-none" title="Copy output to clipboard">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                  </svg>
                </button>
              </div>
              <pre id="output" class="flex-grow p-3 font-mono text-xs text-gray-300 overflow-auto whitespace-pre-wrap break-words">Waiting for command...</pre>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="/static/js/theme.js"></script>
  <script src="/static/js/dashboard.js"></script>

</body>
</html>

