# JWT Secret Key - Change this in production!
# Generate token usign the folloing command
# openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production

# Email Configuration for Password Reset
# Using Gmail as example (you need to enable "Less secure apps" or use app-specific password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@ztna-tools.local

# Application Configuration
# NODE_ENV=development|production
NODE_ENV=production
PORT=8080

# Hostname Caddy should serve and issue a self-signed certificate for.
APP_HOST=tools.example.com

# Network tool execution safeguards
# Maximum runtime per net-tool request (milliseconds)
NET_TOOL_REQUEST_TIMEOUT_MS=15000
# Maximum total streamed output per net-tool request (bytes)
NET_TOOL_MAX_OUTPUT_BYTES=262144

# API rate limiting (applies to all /api/* routes)
# Limit is identity-based (header auth username, bearer token, or cookie user)
API_RATE_LIMIT_MAX_REQUESTS=4
API_RATE_LIMIT_WINDOW_MS=1000
